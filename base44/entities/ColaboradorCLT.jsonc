{
  "name": "ColaboradorCLT",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome do colaborador"
    },
    "unidade": {
      "type": "string",
      "enum": [
        "SP",
        "RJ"
      ],
      "description": "Unidade do colaborador (SP ou RJ)"
    },
    "area": {
      "type": "string",
      "description": "\u00c1rea do colaborador (ex: Cont\u00e1bil, RH)"
    },
    "valor_vr_diario": {
      "type": "number",
      "default": 0,
      "description": "Valor do VR por dia \u00fatil"
    },
    "ativo": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "nome",
    "unidade"
  ]
}